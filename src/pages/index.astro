---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const latestArticles = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="Home" description="The news wire for process servers and legal professionals. AI tools, AB 747 compliance, skip tracing, and industry news — weekly.">

  <!-- Hero -->
  <section class="bg-slate-900 text-white py-16 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-block bg-amber-500 text-slate-900 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-6">
        Free Weekly Newsletter
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
        The news wire for people<br class="hidden sm:block" /> who actually serve.
      </h1>
      <p class="text-slate-300 text-lg mb-8 max-w-xl mx-auto">
        AI tools, AB 747 GPS compliance, skip tracing, and industry news — written by a working process server for process servers.
      </p>

      <!-- Beehiiv embed — replace with actual embed code -->
      <div class="max-w-md mx-auto bg-slate-800 rounded-xl p-6 text-left">
        <p class="text-slate-400 text-sm text-center mb-2">
          [Add Beehiiv subscribe embed here]
        </p>
      </div>
      <p class="text-slate-500 text-xs mt-3">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- Value props -->
  <section class="py-12 px-4 border-b border-slate-100">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      {[
        { icon: '📍', title: 'AB 747 Compliance', desc: 'What GPS documentation actually requires — before the 2027 deadline hits.' },
        { icon: '🤖', title: 'AI Tools That Work', desc: 'Practical reviews of AI tools that save time in the field and at your desk.' },
        { icon: '🔍', title: 'Skip Tracing Tips', desc: 'Free and paid tools compared. What real process servers actually use.' },
      ].map(item => (
        <div class="p-4">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="font-bold text-slate-900 mb-1">{item.title}</h3>
          <p class="text-slate-500 text-sm">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Latest articles -->
  <section class="py-14 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-900">Latest</h2>
        <a href="/articles" class="text-amber-600 text-sm font-medium hover:underline">All articles →</a>
      </div>

      {latestArticles.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestArticles.map(article => (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              slug={article.slug}
              category={article.data.category}
              pubDate={article.data.pubDate}
            />
          ))}
        </div>
      ) : (
        <p class="text-slate-400 text-center py-8">Articles coming soon — subscribe to be first to know.</p>
      )}
    </div>
  </section>

  <!-- Mid-page CTA -->
  <section class="py-8 px-4 bg-slate-50">
    <div class="max-w-4xl mx-auto">
      <NewsletterCTA variant="inline" />
    </div>
  </section>

</BaseLayout>
